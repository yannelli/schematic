{
    "name": "yannelli/schematic",
    "description": "Database-driven templating language with JSON Schema generation for LLM structured outputs",
    "keywords": ["laravel", "template", "json-schema", "openai", "anthropic", "structured-output"],
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "illuminate/database": "^12.0",
        "illuminate/support": "^12.0"
    },
    "require-dev": {
        "orchestra/testbench": "^10.0",
        "pestphp/pest": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Yannelli\\Schematic\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Yannelli\\Schematic\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Yannelli\\Schematic\\SchematicServiceProvider"
            ],
            "aliases": {
                "Schematic": "Yannelli\\Schematic\\Facades\\Schematic"
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
